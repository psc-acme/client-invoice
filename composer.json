{
    "name": "psc-acme/client-invoice",
    "description": "Package client-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ClientInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "psr/cache": "^3.0",
        "illuminate/database": "^11.0",
        "symfony/messenger": "^7.0",
        "nesbot/carbon": "^2.72",
        "aws/aws-sdk-php": "^3.332",
        "psc-acme/loader-billing": "^1.0",
        "psc-acme/proxy-billing": "^1.0",
        "psc-acme/validator-billing": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "symfony/phpunit-bridge": "^7.0",
        "webforge/object-asserter": "^2.0.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}